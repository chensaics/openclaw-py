#!/bin/bash
# Run full test suite before branch push; skip on tag push (release workflow runs tests).
# Install: cp scripts/githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# stdin: <remote> <url> <local_ref> <local_sha> <remote_ref> <remote_sha> per ref
skip_tests=0
while read -r _ _ local_ref _ _ _; do
    case "$local_ref" in refs/tags/*) skip_tests=1; break ;; esac
done
if [ "$skip_tests" = 1 ]; then
    echo "Pre-push: skipping tests (tag push; release workflow will run tests)."
    exit 0
fi
echo "Running pre-push tests..."
python3 -m pytest tests/ -x -q --tb=line 2>/dev/null
if [ $? -ne 0 ]; then
    echo "Tests failed. Push aborted."
    exit 1
fi
