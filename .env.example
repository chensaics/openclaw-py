# ──────────────────────────────────────────────────
# pyclaw 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ──────────────────────────────────────────────────

# ── AI 模型提供商 API Key（按需配置一个或多个）──────

OPENAI_API_KEY=sk-empty
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# FIREWORKS_API_KEY=
# MISTRAL_API_KEY=
# PERPLEXITY_API_KEY=
# MOONSHOT_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
# MINIMAX_API_KEY=
# NVIDIA_API_KEY=

# ── 消息通道凭据（按需配置）─────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=

# Discord
# DISCORD_BOT_TOKEN=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ── pyclaw 核心配置 ─────────────────────────────

# Gateway 认证令牌
# PYCLAW_AUTH_TOKEN=

# Gateway 认证密码
# PYCLAW_GATEWAY_PASSWORD=

# Gateway 端口（默认 18789）
# PYCLAW_GATEWAY_PORT=18789

# Gateway URL（用于远程连接）
# PYCLAW_GATEWAY_URL=

# ── 路径覆盖 ────────────────────────────────────

# 状态目录（默认 ~/.pyclaw）
# PYCLAW_STATE_DIR=

# 配置文件路径（默认 ~/.pyclaw/pyclaw.json）
# PYCLAW_CONFIG_PATH=

# ── 杂项 ────────────────────────────────────────

# 禁用 Bonjour/mDNS 局域网发现
# PYCLAW_DISABLE_BONJOUR=1

# 禁用彩色输出
# NO_COLOR=1
